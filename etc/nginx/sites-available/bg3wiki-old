# Easily toggle logging on/off here
map "" $old_bg3_log {
	default 1;
}

server {
	listen 443 ssl;
	server_name old.bg3.wiki bg3.wiki; # Allow bg3.wiki for fake local requests

	ssl_certificate     /etc/letsencrypt/live/old.bg3.wiki/fullchain.pem;
	ssl_certificate_key /etc/letsencrypt/live/old.bg3.wiki/privkey.pem;

	access_log /var/log/nginx/old-bg3wiki-access.log combined if=$old_bg3_log;
	access_log /var/log/nginx/old-bg3wiki-cache.log mwfc_stats if=$mwfc_log;
	access_log /var/log/nginx/old-bg3wiki-page.log wiki_page if=$wiki_page;
	error_log /var/log/nginx/old-bg3wiki-error.log;

	log_not_found off;

	root /var/www/bg3;

	include headers/default;
	#include headers/unsafe-csp;

	# Catch-all if nothing matches
	location / { return 404; }

	location /payment/ {
		location ~ \.(html|css|js)$ { include headers/cache-15min; }
		location ~ \.php$ { include snippets/run-php-direct; }
		location ~ . { return 404; }
	}

	location = /ads.txt {
		return 307 https://config.playwire.com/dyn_ads/1025372/75208/ads.txt;
	}

	location = /robots.txt {}
	location = /sitemap.xml {}
	location /sitemap/ {
		location ~ \.xml$ {}
		location ~ . { return 404; }
	}

	location = /favicon.ico { include headers/cache-30d; }
	location /static/ {
		location ~ [^/]$ { include headers/cache-30d; }
		location ~ . { return 404; }
	}

	location /js/ {
		location ~ \.js$ { include headers/cache-15min; }
		location ~ . { return 404; }
	}

	location /php/ {
		location ~ \.php$ { include snippets/run-php-direct; }
		location ~ . { return 404; }
	}

	# Root URL is Main Page
	location = /wiki/Main_Page { return 301 /; }
	location = / {
		fastcgi_index w/index.php;
		include snippets/run-php-mwfc;
	}

	# Wiki pages (pretty URLs)
	location /wiki/ { rewrite . /w/index.php; }

	# === Actual MediaWiki installation paths follow ===

	location = /w/index.php { include snippets/run-php-mwfc; }
	location = /w/load.php { include snippets/run-php-mwfc; }
	location = /w/rest.php { include snippets/run-php-mwfc; }
	location = /w/thumb_handler.php { include snippets/run-php-mwfc; }
	location = /w/opensearch_desc.php { include snippets/run-php-mwfc; }
	location = /w/api.php {
		# Block Discord's broken page preview tool
		if ($http_user_agent ~ "Discordbot") { return 403; }
		include snippets/run-php-mwfc;
	}

	# Images
	location /w/images/ {
		location ~ [^/]$ { include headers/cache-1d; }
		location ~ . { return 404; }
	}
	location /w/images/thumb/ {
		location ~ [^/]$ {
			# Use 404 thumb handler if not found
			try_files $uri /w/thumb_handler.php;
			include headers/cache-1d;
		}
		location ~ . { return 404; }
	}
	location /w/images/deleted/ { return 404; }

	# Assets
	location /w/resources/assets/ {
		location ~ [^/]$ { include headers/cache-30d; }
		location ~ . { return 404; }
	}
	location /w/resources/lib/ {
		location ~ [^/]$ { include headers/cache-30d; }
		location ~ . { return 404; }
	}
	location /w/resources/src/ {
		location ~ [^/]$ { include headers/cache-30d; }
		location ~ . { return 404; }
	}
	location /w/extensions/ {
		location ~ \.(css|js|gif|ico|jpe?g|png|svg|webp|wasm|ttf|woff2?)$ {
			include headers/cache-30d;
		}
		location ~ . { return 404; }
	}
	location /w/skins/ {
		location ~ \.(css|js|gif|ico|jpe?g|png|svg|webp|wasm|ttf|woff2?)$ {
			include headers/cache-30d;
		}
		location ~ . { return 404; }
	}

	# REST API
	location /w/rest.php/ { rewrite . /w/rest.php; }
}

# Redirect erroneous www. subdomain requests to main domain.
server {
	listen 443 ssl;
	server_name www.old.bg3.wiki;

	ssl_certificate     /etc/letsencrypt/live/old.bg3.wiki/fullchain.pem;
	ssl_certificate_key /etc/letsencrypt/live/old.bg3.wiki/privkey.pem;

	access_log /var/log/nginx/old-bg3wiki-redir.log combined if=$old_bg3_log;
	error_log /var/log/nginx/old-bg3wiki-error.log;

	return 301 https://old.bg3.wiki$request_uri;
}

# On port 80, handle LetsEncrypt requests, otherwise redirect to HTTPS.
server {
	listen 80;
	server_name old.bg3.wiki www.old.bg3.wiki;

	access_log /var/log/nginx/old-bg3wiki-redir.log combined if=$old_bg3_log;
	error_log /var/log/nginx/old-bg3wiki-error.log;

	include snippets/letsencrypt;

	location / {
		return 301 https://old.bg3.wiki$request_uri;
	}
}
